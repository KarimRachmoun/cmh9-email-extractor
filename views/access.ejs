<!DOCTYPE html>
<html>
<head>
    <title>Access</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-dark text-light">

<div class="container mt-5">
    <div class="card bg-secondary p-4 col-md-6 mx-auto">

        <h3 class="text-center">🔐 Enter Access Code</h3>

        <form method="POST" action="/access">
            <input name="code" class="form-control mb-3" placeholder="Access Code" required>
            <button class="btn btn-warning w-100">Enter</button>
        </form>

        <% if (error) { %>
            <p class="text-danger mt-3 text-center"><%= error %></p>
        <% } %>

    </div>
</div>

</body>
</html>