<!DOCTYPE html>
<html lang="en">

<head>
    <title>Email Extraction CMH9</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #e3f2fd, #ffffff);
            transition: 0.3s;
        }

        body.dark-mode {
            background: linear-gradient(135deg, #0f172a, #1e293b);
            color: #f1f5f9;
        }

        .card-custom {
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.95);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            border: none;
        }

        body.dark-mode .card-custom {
            background: rgba(30, 41, 59, 0.95);
            color: white;
        }

        .btn-extract {
            background: #1e3a8a;
            color: white;
            border: none;
        }

        .btn-extract:hover {
            background: #1e40af;
        }

        .form-control {
            border-radius: 10px;
        }
    </style>
</head>

<body>

    <div class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold">📧 Email Extraction CMH9</h3>
            <button onclick="toggleDarkMode()" class="btn btn-outline-primary">🌙 Mode</button>
        </div>

        <div class="card card-custom p-4">

            <form method="POST">

                <!-- CONNECT -->
                <div class="row g-3 align-items-end mb-4">
                    <div class="col-md-4">
                        <label>Email</label>
                        <input name="email" class="form-control" required value="<%= email || '' %>">
                    </div>

                    <div class="col-md-4">
                        <label>App Password</label>
                        <input type="password" name="password" class="form-control" required
                            value="<%= password || '' %>">
                    </div>

                    <div class="col-md-4">
                        <button formaction="/connect" class="btn btn-primary w-100">🔵 Connect</button>
                    </div>
                </div>

                <hr>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label>Label</label>
                        <select name="label" class="form-control">
                            <% if (labels.length> 0) { %>
                                <% labels.forEach(function(label) { %>
                                    <option value="<%= label %>">
                                        <%= label %>
                                    </option>
                                    <% }) %>
                                        <% } else { %>
                                            <option>Connect First</option>
                                            <% } %>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label>Start From</label>
                        <input type="number" name="start" value="1" class="form-control">
                    </div>

                    <div class="col-md-4">
                        <label>Limit</label>
                        <input type="number" name="limit" value="10" class="form-control">
                    </div>
                </div>

                <!-- RADIO MODES -->
                <div class="mt-4">
                    <label class="fw-bold mb-2">Download Mode</label>

                    <div class="d-flex gap-4">

                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mode" value="clean" checked>
                            <label class="form-check-label">News Clean Headers</label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mode" value="justtext">
                            <label class="form-check-label">Just Text Only</label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mode" value="original">
                            <label class="form-check-label">Newsletter Original</label>
                        </div>



                    </div>
                </div>

                <!-- CLEAN OPTIONS -->
                <div id="cleanOptions" style="display:none;" class="mt-4">

                    <div class="card p-3 bg-light border-0">
                        <h5>Header Modification Options</h5>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label>Domain Replacement</label>
                                <input name="domain" class="form-control" value="[RP]">
                            </div>

                            <div class="col-md-6">
                                <label>Message-ID Tag</label>
                                <input name="eid" class="form-control" value="[EID]">
                            </div>
                        </div>
                        <hr class="my-4">

                        <div class="row">

                            <!-- Row 1 -->
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="replaceDate" checked>
                                    <label class="form-check-label">
                                        Replace Date
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="replaceTo" checked>
                                    <label class="form-check-label">
                                        Replace To
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="keepReceived" checked>
                                    <label class="form-check-label">
                                        Keep Received
                                    </label>
                                </div>
                            </div>

                        </div>

                        <div class="row mt-3">

                            <!-- Row 2 -->
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="keepReplyTo" checked>
                                    <label class="form-check-label">
                                        Keep Reply-To
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="addCc">
                                    <label class="form-check-label">
                                        Auto Add Cc
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="addSender">
                                    <label class="form-check-label">
                                        Add Sender
                                    </label>
                                </div>
                            </div>

                        </div>

                    </div>
                </div>
                <button formaction="/extract" class="btn btn-extract w-100 mt-4">🚀 Start Extraction</button>

            </form>

            <a href="/logout" class="btn btn-outline-danger mt-3 w-100">Logout</a>

            <% if (error) { %>
                <p class="text-danger mt-3">
                    <%= error %>
                </p>
                <% } %>

                    <div class="text-center mt-5 pt-4 border-top">
                        <p class="fw-semibold">CMH9 Team</p>
                        <a href="https://t.me/karim_rachmoun" target="_blank" class="fw-bold text-decoration-none">
                            🔵 Telegram: @karim_rachmoun
                        </a>
                    </div>

        </div>
    </div>

    <script>
        const radios = document.querySelectorAll("input[name='mode']");
        const cleanOptions = document.getElementById("cleanOptions");

        function toggleClean() {
            const selected = document.querySelector("input[name='mode']:checked").value;
            cleanOptions.style.display = selected === "clean" ? "block" : "none";
        }

        radios.forEach(r => r.addEventListener("change", toggleClean));
        toggleClean();

        function toggleDarkMode() {
            document.body.classList.toggle("dark-mode");
        }
    </script>

</body>

</html>