<!DOCTYPE html>
<html lang="en">

<head>
    <title>Email Extractor Pro</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #e3f2fd, #ffffff);
            transition: 0.3s ease;
        }

        body.dark-mode {
            background: linear-gradient(135deg, #0f172a, #1e293b);
            color: #f1f5f9;
        }

        .card-custom {
            border-radius: 20px;
            backdrop-filter: blur(15px);
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            border: none;
        }

        body.dark-mode .card-custom {
            background: rgba(30, 41, 59, 0.95);
            color: white;
        }

        .btn-primary {
            background: #0d6efd;
            border: none;
        }

        .btn-primary:hover {
            background: #0b5ed7;
        }

        .btn-extract {
            background: #1e3a8a;
            color: white;
            border: none;
        }

        .btn-extract:hover {
            background: #1e40af;
        }

        .form-control {
            border-radius: 10px;
        }

        .mode-toggle {
            cursor: pointer;
        }
    </style>
</head>

<body>

    <div class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold">📧 Email Extraction CMH9</h3>
            <button onclick="toggleDarkMode()" class="btn btn-outline-primary mode-toggle">
                🌙  Mode
            </button>
        </div>

        <div class="card card-custom p-4">

            <form method="POST">

                <!-- CONNECT LINE -->
                <div class="row g-3 align-items-end mb-4">
                    <div class="col-md-4">
                        <label>Email</label>
                        <input name="email" class="form-control" required value="<%= email || '' %>">
                    </div>

                    <div class="col-md-4">
                        <label>App Password</label>
                        <input type="password" name="password" class="form-control" required
                            value="<%= password || '' %>">
                    </div>

                    <div class="col-md-4">
                        <button formaction="/connect" class="btn btn-primary w-100">
                            🔵 Connect
                        </button>
                    </div>
                </div>

                <hr>

                <!-- EXTRACTION SETTINGS -->

                <div class="row g-3">

                    <div class="col-md-4">
                        <label>Label</label>
                        <select name="label" class="form-control">
                            <% if (labels.length> 0) { %>
                                <% labels.forEach(function(label) { %>
                                    <option value="<%= label %>">
                                        <%= label %>
                                    </option>
                                    <% }) %>
                                        <% } else { %>
                                            <option>Connect First</option>
                                            <% } %>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label>Start From</label>
                        <input type="number" name="start" value="1" class="form-control">
                    </div>

                    <div class="col-md-4">
                        <label>Limit</label>
                        <input type="number" name="limit" value="10" class="form-control">
                    </div>

                </div>

                <div class="mt-4">
                    <label>Download Mode</label>
                    <select name="mode" id="modeSelect" class="form-control">
                        <option value="newsletter">Download Newsletter</option>
                        <option value="original">Download Original (Raw)</option>
                        <option value="original_clean">Original Clean (Modify Headers)</option>
                    </select>
                </div>

                <!-- CLEAN OPTIONS -->

                <div id="cleanOptions" style="display:none;" class="mt-4">

                    <div class="card p-3 bg-light border-0">
                        <h5 class="mb-3">Header Modification Options</h5>

                        <div class="row g-3">

                            <div class="col-md-6">
                                <label>Domain Replacement</label>
                                <input name="domain" class="form-control" placeholder="example.com">
                            </div>

                            <div class="col-md-6">
                                <label>Message-ID Tag (Before @)</label>
                                <input name="eid" class="form-control" placeholder="[EID]">
                            </div>

                        </div>

                        <hr class="my-4">

                        <div class="row">

                            <!-- Row 1 -->
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="replaceDate" checked>
                                    <label class="form-check-label">
                                        Replace Date
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="replaceTo" checked>
                                    <label class="form-check-label">
                                        Replace To
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="keepReceived" checked>
                                    <label class="form-check-label">
                                        Keep Received
                                    </label>
                                </div>
                            </div>

                        </div>

                        <div class="row mt-3">

                            <!-- Row 2 -->
                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="keepReplyTo" checked>
                                    <label class="form-check-label">
                                        Keep Reply-To
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="addCc">
                                    <label class="form-check-label">
                                        Auto Add Cc
                                    </label>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="addSender">
                                    <label class="form-check-label">
                                        Add Sender
                                    </label>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>

        </div>

        <button formaction="/extract" class="btn btn-extract w-100 mt-4 py-2">
            🚀 Start Extraction
        </button>

        </form>

        <a href="/logout" class="btn btn-outline-danger mt-3 w-100">Logout</a>

        <% if (error) { %>
            <p class="text-danger mt-3">
                <%= error %>
            </p>
            <% } %>

            <div class="text-center mt-5 pt-4 border-top">
    <p class="mb-1 fw-semibold">CMH9 Team</p>
    <a href="https://t.me/karim_rachmoun" target="_blank" 
       class="text-decoration-none fw-bold">
        🔵 Telegram: @karim_rachmoun
    </a>
</div>
    </div>
    </div>
    

    <script>
        const modeSelect = document.getElementById("modeSelect");
        const cleanOptions = document.getElementById("cleanOptions");

        function toggleCleanOptions() {
            cleanOptions.style.display =
                modeSelect.value === "original_clean" ? "block" : "none";
        }

        modeSelect.addEventListener("change", toggleCleanOptions);
        toggleCleanOptions();

        function toggleDarkMode() {
            document.body.classList.toggle("dark-mode");
        }
    </script>

</body>

</html>